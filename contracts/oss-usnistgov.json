    "title": "full_name",
    "url": "html_url",
    "description": "description",
    "date": "pushed_at",
    "stars": "stargazers_count"
  },
  "exclude": [
    "\"archived\":true"
  ],
  "min_records": 1,
  "max_delta_pct": 100,
  "notes": "NIST GitHub org (standards, crypto, AI risk frameworks), non-archived.",
