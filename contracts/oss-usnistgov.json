{
  "id": "oss-usnistgov",
  "tracker": "oss-index",
  "method": "api",
  "url": "https://api.github.com/orgs/usnistgov/repos",
  "enabled": true,
  "cadence_hours": 24,
  "rate_limit_ms": 2000,
  "auth_env": "GITHUB_TOKEN",
  "auth_mode": "header",
  "paginate": "page",
  "per_page": 100,
  "max_pages": 1,
  "array_path": "",
  "key_field": "full_name",
