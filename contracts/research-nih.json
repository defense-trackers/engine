{
  "id": "research-nih",
  "tracker": "research-funding",
  "method": "api",
  "url": "https://api.reporter.nih.gov/v2/projects/search",
  "enabled": false,
  "cadence_hours": 168,
  "rate_limit_ms": 1000,
  "http_method": "POST",
  "body": "{\"criteria\":{\"text_search\":\"artificial intelligence\"},\"limit\":50,\"offset\":0,\"sort_field\":\"project_start_date\",\"sort_order\":\"desc\"}",
  "array_path": "results",
  "key_field": "appl_id",
  "field_map": { "title": "project_title", "awardee": "organization.org_name", "amount": "award_amount", "date": "project_start_date" },
  "url_template": "https://reporter.nih.gov/project-details/{appl_id}",
  "include": ["artificial intelligence", "machine learning", "deep learning", "neural network"],
  "date_field": "date",
  "min_records": 1,
  "max_delta_pct": 100,
  "notes": "DISABLED: NIH text-search returns biomedical research that only loosely mentions AI (antifungals, depression studies) — off-domain for a defense-innovation tracker and noisy. NSF carries research-funding."
}
