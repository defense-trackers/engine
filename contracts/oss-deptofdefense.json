{
  "id": "oss-deptofdefense",
  "tracker": "oss-index",
  "method": "api",
  "url": "https://api.github.com/orgs/deptofdefense/repos",
  "enabled": false,
  "cadence_hours": 24,
  "rate_limit_ms": 2000,
  "auth_env": "GITHUB_TOKEN",
  "auth_mode": "header",
  "paginate": "page",
  "per_page": 100,
  "max_pages": 2,
  "array_path": "",
  "key_field": "full_name",
  "field_map": { "title": "full_name", "url": "html_url", "description": "description", "date": "pushed_at", "stars": "stargazers_count" },
  "exclude": ["\"archived\":true"],
  "min_records": 1,
  "max_delta_pct": 100,
  "notes": "DISABLED: every repo in the deptofdefense org is archived (org is effectively dead), so the maintained-only filter leaves nothing. Live gov OSS comes from cisagov / ngageoint / nsacyber."
}
