{
  "id": "policy-eo",
  "tracker": "policy",
  "method": "api",
  "url": "https://www.federalregister.gov/api/v1/documents.json",
  "enabled": true,
  "cadence_hours": 24,
  "rate_limit_ms": 1000,
  "query": { "conditions[term]": "artificial intelligence", "conditions[type][]": "PRESDOCU", "order": "newest", "per_page": "50" },
  "array_path": "results",
  "key_field": "document_number",
  "field_map": { "title": "title", "type": "type", "date": "publication_date", "url": "html_url" },
  "include": ["artificial intelligence", "machine learning", "generative ai", "large language model", "autonomous system", "autonomous weapon"],
  "include_fields": ["title", "abstract"],
  "date_field": "date",
  "min_records": 1,
  "max_delta_pct": 100,
  "notes": "Presidential documents (executive orders, memoranda, proclamations) mentioning AI — the highest-signal policy layer."
}
