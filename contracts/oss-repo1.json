{
  "id": "oss-repo1",
  "tracker": "oss-index",
  "method": "api",
  "url": "https://repo1.dso.mil/api/v4/projects",
  "enabled": false,
  "cadence_hours": 24,
  "rate_limit_ms": 1000,
  "query": {
    "order_by": "last_activity_at",
    "visibility": "public"
  },
  "paginate": "page",
  "per_page": 50,
  "max_pages": 1,
  "array_path": "",
  "key_field": "id",
  "field_map": {
    "title": "name_with_namespace",
    "url": "web_url",
    "description": "description",
    "date": "last_activity_at",
    "stars": "star_count"
  },
  "min_records": 1,
  "max_delta_pct": 100,
  "notes": "DISABLED: returns Iron Bank container infra (overlaps authorizations) rather than discrete OSS projects. Re-enable with a tighter project filter if desired.",
  "recent_field": "last_activity_at",
  "recent_days": 365,
  "include": [
    "ai",
    "ml",
    "machine learning",
    "autonomy",
    "autonomous",
    "drone",
    "uav",
    "uas",
    "unmanned",
    "swarm",
    "mesh",
    "tactical",
    "tak",
    "cursor on target",
    "isr",
    "sensor",
    "thermal",
    "infrared",
    "perception",
    "detection",
    "tracking",
    "targeting",
    "logistics",
    "sustainment",
    "inference",
    "llm",
    "transformer",
    "neural",
    "edge",
    "embedded",
    "geospatial",
    "satellite",
    "orbit",
    "space",
    "rf",
    "radio",
    "signal",
    "sdr",
    "spectrum",
    "crypto",
    "cyber",
    "security",
    "zero-trust",
    "zero trust",
    "vulnerability",
    "exploit",
    "malware",
    "reverse",
    "simulation",
    "mission",
    "weapon",
    "missile",
    "radar",
    "sonar",
    "navigation",
    "pnt",
    "fpga",
    "firmware",
    "c2",
    "command and control"
  ],
  "include_fields": [
    "full_name",
    "name",
    "description",
    "topics"
  ],
  "allow_empty": true
}
