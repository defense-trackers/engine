{
  "id": "transition-usaspending",
  "tracker": "transition",
  "method": "api",
  "url": "https://api.usaspending.gov/api/v2/search/spending_by_award/",
  "enabled": true,
  "cadence_hours": 168,
  "rate_limit_ms": 1000,
  "http_method": "POST",
  "body": "{\"filters\":{\"award_type_codes\":[\"A\",\"B\",\"C\",\"D\"],\"agencies\":[{\"type\":\"awarding\",\"tier\":\"toptier\",\"name\":\"Department of Defense\"}],\"time_period\":[{\"start_date\":\"{{today-365d}}\",\"end_date\":\"{{today}}\"}]},\"fields\":[\"Award ID\",\"Recipient Name\",\"Award Amount\",\"Awarding Agency\",\"Description\"],\"limit\":50,\"page\":1,\"sort\":\"Award Amount\",\"order\":\"desc\"}",
  "array_path": "results",
  "key_field": "generated_internal_id",
  "field_map": { "title": "Recipient Name", "award_id": "Award ID", "amount": "Award Amount", "agency": "Awarding Agency", "description": "Description" },
  "min_records": 1,
  "max_delta_pct": 100,
  "notes": "Largest DoD contract awards (rolling 1-year window via {{today-365d}}..{{today}}) from USAspending. Confirmed shape (results[]). The production-dollar signal; pairs with prototype OTs for the full valley-of-death story."
}
