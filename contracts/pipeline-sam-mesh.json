{
  "id": "pipeline-sam-mesh",
  "tracker": "pipeline",
  "method": "api",
  "url": "https://api.sam.gov/prod/opportunities/v2/search",
  "enabled": true,
  "cadence_hours": 24,
  "rate_limit_ms": 1500,
  "auth_env": "SAM_API_KEY",
  "auth_mode": "header:X-Api-Key",
  "query": {
    "limit": "100",
    "postedFrom": "{{today_us-180d}}",
    "postedTo": "{{today_us}}",
    "title": "mesh network"
  },
  "array_path": "opportunitiesData",
  "key_field": "noticeId",
  "field_map": {
    "title": "title",
    "agency": "fullParentPathName",
    "posted": "postedDate",
    "closes": "responseDeadLine",
    "number": "solicitationNumber",
    "type": "type",
    "setaside": "typeOfSetAsideDescription",
    "url": "uiLink"
  },
  "include": ["Defense", "Air Force", "Army", "Navy", "Space", "DARPA", "Marine Corps"],
  "include_fields": ["fullParentPathName"],
  "exclude": ["Award Notice", "Justification", "Radiology", "Clinical", "Dental", "Nursing", "Behavioral Health", "Medical Center", "Pharmac"],
  "date_field": "closes",
  "min_records": 0,
  "max_delta_pct": 100,
  "notes": "SAM.gov contract opportunities, title 'mesh network', DoD-filtered. Mesh-net assurance domain (low volume, high signal)."
}
